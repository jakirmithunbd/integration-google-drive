{
    "name": "integration-google-drive",
    "version": "1.4.2",
    "private": true,
    "type": "module",
    "description": "A simple modern wordpress google cloud storage plugin",
    "files": [
        "app",
        "assets",
        "core",
        "freemius",
        "plugin-update-checker",
        "includes",
        "models",
        "templates",
        "vendors",
        "index.php",
        "integration-google-drive.php",
        "readme.txt"
    ],
    "scripts": {
        "cc-start": "wp-env start",
        "cc-stop": "wp-env stop",
        "dev-admin": "webpack serve --config webpack.dev.config.js",
        "build-admin": "webpack --config webpack.prod.config.js",
        "watch-assets": "wp-scripts start --config webpack.dev.config.js",
        "watch-sass": "sass --watch source/assets/sass:assets/css --style=expanded",
        "buildSass": "sass source/assets/sass:assets/css --style=compressed --no-source-map",
        "buildPostcss": "postcss assets/css/**/*.css --replace --no-map",
        "start": "concurrently \"npm:watch-*\"",
        "dev-hot": "concurrently \"npm:watch-sass\" \"npm:dev-admin\" ",
        "clean-maps": "find . \\( -name \"*.map\" -o -name \".DS_Store\" \\) -type f -delete",
        "plugin:zip": "wp-scripts plugin-zip",
        "build": "npm run buildSass && npm run buildPostcss && concurrently \"npm:build-*\" && npm run clean-maps",
        "build:zip": "npm run build && npm run plugin:zip"
    },
    "keywords": [
        "wordpress",
        "google-drive",
        "google-cloud-storage",
        "google-drive-api",
        "google-drive-plugin"
    ],
    "author": "CodeConfig",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^22.15.17",
        "@types/plupload": "^2.0.14",
        "@types/wordpress__block-editor": "^11.5.17",
        "@wordpress/block-editor": "^15.5.0",
        "@wordpress/components": "^30.5.0",
        "@wordpress/element": "^6.23.0",
        "@wordpress/env": "^10.39.0",
        "@wordpress/i18n": "^5.6.0",
        "@wordpress/scripts": "^31.4.0",
        "autoprefixer": "^10.4.21",
        "concurrently": "^8.2.2",
        "copy-webpack-plugin": "^13.0.0",
        "cssnano": "^7.0.7",
        "glob": "^11.0.2",
        "plupload": "^2.3.9",
        "postcss": "^8.5.3",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^10.4.0",
        "swiper": "^11.2.10",
        "typescript": "^5.6.3",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.3.0",
        "clsx": "^2.1.1",
        "react-photo-album": "^3.1.0",
        "react-redux": "^9.1.2",
        "react-router-dom": "^7.6.1",
        "sass": "^1.77.8"
    }
}
